<Window x:Class="ShoeStore.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование товара" Height="650" Width="500"
        WindowStartupLocation="CenterOwner"
        FontFamily="Times New Roman" FontSize="14"
        ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Редактирование товара" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Фото товара:" Margin="0,8,0,2" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Image Name="imgProduct" Width="100" Height="80" Stretch="Uniform" Margin="0,0,10,0"/>
                <Button Name="btnLoadImage" Content="Выбрать фото" Width="100" Height="30" Click="BtnLoadImage_Click" Background="#CCCCCC" Cursor="Hand"/>
            </StackPanel>

            <TextBlock Text="ID товара:" Margin="0,8,0,2" FontWeight="Bold"/>
            <TextBox Name="txtId" IsReadOnly="True" Background="#F0F0F0" Margin="0,0,0,10" Height="30" Padding="5"/>

            <TextBlock Text="Название:" Margin="0,8,0,2" FontWeight="Bold"/>
            <TextBox Name="txtName" Margin="0,0,0,10" Height="30" Padding="5"/>

            <TextBlock Text="Категория:" Margin="0,8,0,2" FontWeight="Bold"/>
            <ComboBox Name="cmbCategory" Margin="0,0,0,10" Height="30" DisplayMemberPath="name" SelectedValuePath="id"/>

            <TextBlock Text="Производитель:" Margin="0,8,0,2" FontWeight="Bold"/>
            <ComboBox Name="cmbManufacturer" Margin="0,0,0,10" Height="30" DisplayMemberPath="name" SelectedValuePath="id"/>

            <TextBlock Text="Поставщик:" Margin="0,8,0,2" FontWeight="Bold"/>
            <TextBox Name="txtSupplier" Margin="0,0,0,10" Height="30" Padding="5"/>

            <TextBlock Text="Цена:" Margin="0,8,0,2" FontWeight="Bold"/>
            <TextBox Name="txtPrice" Margin="0,0,0,10" Height="30" Padding="5"/>

            <TextBlock Text="Количество:" Margin="0,8,0,2" FontWeight="Bold"/>
            <TextBox Name="txtQuantity" Margin="0,0,0,10" Height="30" Padding="5"/>

            <TextBlock Text="Скидка (%):" Margin="0,8,0,2" FontWeight="Bold"/>
            <TextBox Name="txtDiscount" Margin="0,0,0,20" Height="30" Padding="5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                <Button Content="Сохранить" Width="100" Height="35" Margin="5" Click="BtnSave_Click" Background="#00FA9A" Cursor="Hand"/>
                <Button Content="Удалить" Width="100" Height="35" Margin="5" Name="btnDelete" Click="BtnDelete_Click" Background="#FF6B6B" Cursor="Hand"/>
                <Button Content="Отмена" Width="100" Height="35" Margin="5" Click="BtnCancel_Click" Background="#CCCCCC" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>