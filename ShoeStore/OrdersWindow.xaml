<Window x:Class="ShoeStore.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление заказами" Height="500" Width="850"
        WindowStartupLocation="CenterOwner"
        FontFamily="Times New Roman" FontSize="14"
        MinHeight="400" MinWidth="700">

    <DockPanel Margin="10">

        <Button DockPanel.Dock="Bottom" Name="btnAdd" Content="Добавить заказ" 
                Width="130" Height="35" HorizontalAlignment="Right"
                Margin="0,10,0,0" Click="BtnAdd_Click" 
                Background="#00FA9A" Cursor="Hand"/>

        <DataGrid Name="dgOrders" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" 
                  MouseDoubleClick="DgOrders_MouseDoubleClick"
                  FontSize="13" AlternatingRowBackground="#F9F9F9"
                  RowHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding article}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding status}" Width="120"/>
                <DataGridTextColumn Header="Адрес выдачи" Binding="{Binding pickup_address}" Width="300"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding order_date}" Width="100"/>
                <DataGridTextColumn Header="Дата выдачи" Binding="{Binding issue_date}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>