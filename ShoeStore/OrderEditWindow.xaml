<Window x:Class="ShoeStore.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заказа" Height="450" Width="480"
        WindowStartupLocation="CenterOwner"
        FontFamily="Times New Roman" FontSize="14"
        ResizeMode="NoResize">

    <StackPanel Margin="20">

        <TextBlock Text="Редактирование заказа" 
                   FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Артикул -->
        <TextBlock Text="Артикул:" Margin="0,8,0,2" FontWeight="Bold"/>
        <TextBox Name="txtArticle" Margin="0,0,0,10" Height="30" Padding="5"/>

        <!-- Статус -->
        <TextBlock Text="Статус заказа:" Margin="0,8,0,2" FontWeight="Bold"/>
        <ComboBox Name="cmbStatus" Margin="0,0,0,10" Height="30">
            <ComboBoxItem Content="Новый"/>
            <ComboBoxItem Content="В обработке"/>
            <ComboBoxItem Content="Готов к выдаче"/>
            <ComboBoxItem Content="Выдан"/>
        </ComboBox>

        <!-- Адрес -->
        <TextBlock Text="Адрес пункта выдачи:" Margin="0,8,0,2" FontWeight="Bold"/>
        <TextBox Name="txtAddress" Margin="0,0,0,10" Height="30" Padding="5"/>

        <!-- Дата заказа -->
        <TextBlock Text="Дата заказа:" Margin="0,8,0,2" FontWeight="Bold"/>
        <DatePicker Name="dpOrderDate" Margin="0,0,0,10" Height="30"/>

        <!-- Дата выдачи -->
        <TextBlock Text="Дата выдачи:" Margin="0,8,0,2" FontWeight="Bold"/>
        <DatePicker Name="dpIssueDate" Margin="0,0,0,20" Height="30"/>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Сохранить" Width="100" Height="35" Margin="5"
                    Click="BtnSave_Click" Background="#00FA9A" Cursor="Hand"/>
            <Button Content="Удалить" Width="100" Height="35" Margin="5"
                    Name="btnDelete" Click="BtnDelete_Click" Background="#FF6B6B" Cursor="Hand"/>
            <Button Content="Отмена" Width="100" Height="35" Margin="5"
                    Click="BtnCancel_Click" Background="#CCCCCC" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>