<Window x:Class="ShoeStore.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заказа" Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        FontFamily="Times New Roman" FontSize="14"
        ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">

            <TextBlock Text="Редактирование заказа" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Артикул:" Margin="0,10,0,5" FontWeight="Bold"/>
            <TextBox Name="txtArticle" Margin="0,0,0,15" Height="35" Padding="8" FontSize="14"/>

            <TextBlock Text="Статус заказа:" Margin="0,10,0,5" FontWeight="Bold"/>
            <ComboBox Name="cmbStatus" Margin="0,0,0,15" Height="35" FontSize="14">
                <ComboBoxItem Content="Новый"/>
                <ComboBoxItem Content="В обработке"/>
                <ComboBoxItem Content="Готов к выдаче"/>
                <ComboBoxItem Content="Выдан"/>
            </ComboBox>

            <TextBlock Text="Адрес пункта выдачи:" Margin="0,10,0,5" FontWeight="Bold"/>
            <TextBox Name="txtAddress" Margin="0,0,0,15" Height="35" Padding="8" FontSize="14"/>

            <TextBlock Text="Дата заказа:" Margin="0,10,0,5" FontWeight="Bold"/>
            <DatePicker Name="dpOrderDate" Margin="0,0,0,15" Height="35" FontSize="14"/>

            <TextBlock Text="Дата выдачи:" Margin="0,10,0,5" FontWeight="Bold"/>
            <DatePicker Name="dpIssueDate" Margin="0,0,0,25" Height="35" FontSize="14"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,20">
                <Button Content="Сохранить" Width="120" Height="40" Margin="10" Click="BtnSave_Click" Background="#00FA9A" Cursor="Hand" FontSize="14" FontWeight="Bold"/>
                <Button Content="Удалить" Width="120" Height="40" Margin="10" Name="btnDelete" Click="BtnDelete_Click" Background="#FF6B6B" Cursor="Hand" FontSize="14" FontWeight="Bold"/>
                <Button Content="Отмена" Width="120" Height="40" Margin="10" Click="BtnCancel_Click" Background="#CCCCCC" Cursor="Hand" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>